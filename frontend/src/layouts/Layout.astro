---
import { social } from "../utils/config";

interface Props {
  title?: string;
  showSocial?: boolean;
  frontmatter?: { title?: string; showSocial?: boolean; date?: string };
}

const frontmatter = Astro.props.frontmatter ?? {};
const title = frontmatter.title ?? Astro.props.title ?? "Barath GaneshKumar";
const showSocial = frontmatter.showSocial ?? Astro.props.showSocial ?? false;
const date = frontmatter.date ? new Date(frontmatter.date).toISOString().split("T")[0] : null;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  </head>
  <body>
    <header>
      <h1><a href="/">Barath GaneshKumar</a></h1>
    </header>

    {showSocial && (
      <div class="social-links">
        {social.github   && <a href={`https://github.com/${social.github}`} target="_blank" rel="noopener">GitHub</a>}
        {social.linkedin && <a href={`https://linkedin.com/in/${social.linkedin}`} target="_blank" rel="noopener">LinkedIn</a>}
        {social.twitter  && <a href={`https://twitter.com/${social.twitter}`} target="_blank" rel="noopener">Twitter</a>}
        {social.email    && <a href={`mailto:${social.email}`}>Email</a>}
        {social.resume   && <a href={social.resume} target="_blank" rel="noopener">Resume</a>}
      </div>
    )}

    <main>
      {date && (
        <div class="post-header">
          <h2 class="post-title">{title}</h2>
          <time class="post-date">{date}</time>
        </div>
      )}
      <slot />
    </main>
  </body>
</html>

<style is:global>
  :root {
    --content-width: 680px;
    --page-padding-x: 1.5rem;
    --page-padding-y: 3rem;

    --text-base: 0.85rem;
    --text-h1:   1.5rem;
    --text-h2:   1.25rem;
    --text-h3:   1rem;
    --text-h4:   1rem;
    --text-h5:   0.9rem;
    --text-h6:   0.8rem;
  }

  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: var(--text-base);
    line-height: 1.75;
    max-width: var(--content-width);
    margin: 0 auto;
    padding: var(--page-padding-y) var(--page-padding-x);
    min-height: 100vh;
  }

  h1, h2, h3, h4, h5, h6 {
    font-weight: 600;
    line-height: 1.3;
    margin-top: 1.75em;
    margin-bottom: 0.5em;
  }

  h1 { font-size: var(--text-h1); }
  h2 { font-size: var(--text-h2); }
  h3 { font-size: var(--text-h3); }
  h4 { font-size: var(--text-h4); }
  h5 { font-size: var(--text-h5); }
  h6 { font-size: var(--text-h6); }

  p { margin-bottom: 1em; }

  ul, ol {
    padding-left: 1.5em;
    margin-bottom: 1em;
  }

  header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 2rem;
  }

  header h1 {
    margin: 0;
    font-size: 1.5rem;
  }

  header h1 a {
    color: inherit;
    text-decoration: none;
  }

  nav {
    display: flex;
    gap: 1.5rem;
  }

  nav a {
    font-size: 0.9rem;
    color: inherit;
    text-decoration: none;
  }

  nav a:hover {
    text-decoration: underline;
  }

  .social-links {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  main {
    margin-top: 4rem;
  }

  @media (max-width: 1023px) {
    main { margin-top: 3rem; }
  }

  @media (max-width: 767px) {
    main { margin-top: 2rem; }
  }

  .social-links a {
    font-size: 0.85rem;
    color: inherit;
    text-decoration: none;
  }

  .social-links a:hover {
    text-decoration: underline;
  }

  .post-header {
    margin-bottom: 2rem;
  }

  .post-title {
    font-size: 1.5rem;
    margin: 0 0 0.25rem;
  }

  .post-date {
    font-size: 0.8rem;
    color: #888;
  }
</style>
